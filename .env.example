# ============================================================
# Marketplace Hub — Environment Variables Template
# ============================================================
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local or any file with real secrets.
# ============================================================

# ── Supabase ──────────────────────────────────────────────
# Public — safe to expose to the browser
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-key>

# SECRET — server-only, never use NEXT_PUBLIC_ prefix
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# ── Encryption ────────────────────────────────────────────
# AES-256-GCM key: exactly 64 hex chars (32 bytes)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=<64-hex-chars>

# ── Application ───────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── AI / Groq ─────────────────────────────────────────────
# Free tier: 14,400 req/day — https://console.groq.com
GROQ_API_KEY=gsk_<your-groq-key>

# ── Cron Security ─────────────────────────────────────────
# Random secret to validate Vercel Cron calls
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=<64-hex-chars>

# ── OAuth — Bling ERP ─────────────────────────────────────
# Register at: https://developer.bling.com.br
BLING_CLIENT_ID=<your-client-id>
BLING_CLIENT_SECRET=<your-client-secret>

# ── OAuth — Mercado Livre ─────────────────────────────────
# Register at: https://developers.mercadolivre.com.br
ML_CLIENT_ID=<your-app-id>
ML_CLIENT_SECRET=<your-client-secret>
